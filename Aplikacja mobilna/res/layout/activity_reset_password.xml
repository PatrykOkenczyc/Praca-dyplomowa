<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg">


    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/arrow"
        android:tint="@color/textMain"
        android:layout_marginBottom="16dp"
        android:clickable="true"
        android:focusable="true"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">




        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wymagania hasła:"
            android:textColor="@color/textMain"
            android:textStyle="bold"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/ruleLength"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Minimum 8 znaków"
            android:textColor="@color/textSecondary"
            android:drawableStart="@drawable/invalid"
            android:drawablePadding="8dp"
            android:padding="4dp"/>

        <TextView
            android:id="@+id/ruleLower"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mała litera (a–z)"
            android:textColor="@color/textSecondary"
            android:drawableStart="@drawable/invalid"
            android:drawablePadding="8dp"
            android:padding="4dp"/>

        <TextView
            android:id="@+id/ruleUpper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wielka litera (A–Z)"
            android:textColor="@color/textSecondary"
            android:drawableStart="@drawable/invalid"
            android:drawablePadding="8dp"
            android:padding="4dp"/>

        <TextView
            android:id="@+id/ruleDigit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cyfra (0–9)"
            android:textColor="@color/textSecondary"
            android:drawableStart="@drawable/invalid"
            android:drawablePadding="8dp"
            android:padding="4dp"/>

        <TextView
            android:id="@+id/ruleSpecial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Znak specjalny (!@#\$%*)"
            android:textColor="@color/textSecondary"
            android:drawableStart="@drawable/invalid"
            android:drawablePadding="8dp"
            android:padding="4dp"/>


        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nowe hasło"
            android:textColor="@color/textMain"
            android:textColorHint="@color/textSecondary"
            android:backgroundTint="@color/primary"
            android:inputType="textPassword"
            android:drawableEnd="@drawable/visibility_off"
            android:drawableTint="@color/textMain"
            android:paddingEnd="12dp"/>


        <EditText
            android:id="@+id/etPasswordRepeat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Powtórz hasło"
            android:textColor="@color/textMain"
            android:textColorHint="@color/textSecondary"
            android:backgroundTint="@color/primary"
            android:inputType="textPassword"
            android:drawableEnd="@drawable/visibility_off"
            android:drawableTint="@color/textMain"
            android:paddingEnd="12dp"
            android:layout_marginTop="16dp"/>

        <Button
            android:id="@+id/btnResetPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zmień hasło"
            android:backgroundTint="@color/primary"
            android:textColor="@color/bg"
            android:layout_marginTop="24dp"/>

    </LinearLayout>

</LinearLayout>